    {
        "id": "7f793375b40450fb",
        "type": "function",
        "z": "8d441b1e1f9e38da",
        "name": "SelectToSeeIfOrderFinished",
        "func": "if (!msg.next_product) {\n    return null;\n}\n\nmsg.payload = [msg.order_id];\n\nmsg.topic = `\n    SELECT\n        p.productSN, p.order_id, p.cart_id, p.status,\n        o.nb_product,\n        pr.*\n    FROM Production p\n    JOIN Orders o ON p.order_id = o.order_id\n    JOIN Products pr ON pr.product_type = o.product_type\n    WHERE p.status = 'FINISHED' AND p.order_id = ?;\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 840,
