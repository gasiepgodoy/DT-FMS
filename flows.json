    {
        "id": "8d085d44ed72ad0c",
        "type": "function",
        "z": "8d441b1e1f9e38da",
        "name": "AreAnyOrderPending?",
        "func": "let totalProducts = msg.payload[0].nb_product;\nlet finishedProducts = msg.payload.length;\n\nlet remainingProducts = totalProducts - finishedProducts;\nmsg.remainingProducts = remainingProducts;\n\nif (remainingProducts > 0) {\n    msg.productData = msg.payload[0];\n    msg.order_id = msg.payload[0].order_id;\n    msg.production_status = \"PENDING\";\n    return [msg, null]; \n} else {\n    msg.production_status = \"FINISHED\";\n    return [null, msg]; \n}",
        "outputs": 2,
