    {
        "id": "ebc4145927af70fe",
        "type": "function",
        "z": "8d441b1e1f9e38da",
        "name": "AcknowledgePhysicalAnswer",
        "func": "let machineAnswer = msg.payload; \nlet sn = machineAnswer.sn;\nlet cart = flow.get('cart_' + sn);\n\nif (!cart) return null;\n\nif (machineAnswer.response === \"ACK\" && cart.state === 'ACK_WAIT') {\n    cart.state = 'DONE_WAIT';\n    flow.set('cart_' + sn, cart);\n    return { payload: `[Product ${sn}] ACK received. Operation in progress...` };\n}\n\nif (machineAnswer.response === \"DONE\" && cart.state === 'DONE_WAIT') {\n    cart.state = 'EVALUATION';\n    cart.currentStation++;\n    flow.set('cart_' + sn, cart);\n    \n    return [\n        { payload: `[Product ${sn}] MOVE CART` }, \n        { payload: { action: 'DECISION', sn: sn } } \n    ];\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
